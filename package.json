{
  "name": "mdview",
  "version": "0.1.0",
  "private": false,
  "description": "Terminal markdown previewer with live reload",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "mdview": "dist/main.js"
  },
  "files": [
    "dist",
    "completions"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "package:binaries": "bun build src/main.ts --compile --outfile release/mdview",
    "install:binary": "node scripts/install-binary.mjs"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "string-width": "^7.2.0",
    "unified": "^11.0.5",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "@types/react": "^18.3.24",
    "react-devtools-core": "^4.28.5",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
